# Порт HTTP-сервера
PORT=3000

# --- Telegram ---
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# ID чата/канала, куда слать заявки (узнать через @userinfobot или getUpdates)
TELEGRAM_CHAT_ID=

# --- SMTP (nodemailer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# От кого уходит письмо, например: "Загород <noreply@zagorod.ru>"
MAIL_FROM=
# Куда падают заявки. Можно несколько адресов через запятую
MAIL_TO=

# --- Антиспам ---
# Максимум заявок с одного IP в минуту
RATE_LIMIT_PER_MIN=5
