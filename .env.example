# Порт HTTP-сервера
PORT=3000

# --- Telegram ---
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=
# ID чата/канала, куда слать заявки (узнать через @userinfobot или getUpdates)
TELEGRAM_CHAT_ID=

# --- SMTP (nodemailer) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# От кого уходит письмо, например: "Загород <noreply@zagorod.ru>"
MAIL_FROM=
# Куда падают заявки. Можно несколько адресов через запятую
MAIL_TO=

# --- Антиспам ---
# Максимум заявок с одного IP в минуту
RATE_LIMIT_PER_MIN=5

# --- Админ-панель через бота (смена цен и занятости) ---
# Папка постоянного хранилища (на Railway смонтируй Volume сюда). Локально можно не задавать.
DATA_DIR=/data
# Публичный адрес сайта (для webhook Telegram)
PUBLIC_URL=https://kir-production-acb6.up.railway.app
# Секрет для пути/заголовка webhook (любая строка A-Za-z0-9_-)
TG_WEBHOOK_SECRET=gp-wh-4f9a2c81
# Telegram-id админов, которым можно менять цены/занятость (через запятую)
ADMIN_IDS=7738750071,1203192763
